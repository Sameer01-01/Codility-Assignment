# Database and Redis Configuration
DATABASE_URL="postgresql://root:root@localhost:5432/jobscheduler?schema=public"
REDIS_URL="redis://localhost:6379"

# API Service Configuration
PORT=3000
JWT_SECRET="super-secret-jwt-signing-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-jwt-refresh-signing-key"
FRONTEND_URL="http://localhost:5173"

# Worker Configuration
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=5000
REAPER_INTERVAL_MS=10000
STALE_WORKER_TIMEOUT_MS=15000
