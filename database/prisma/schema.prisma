datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MEMBER
}

enum QueueStatus {
  ACTIVE
  PAUSED
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum ExecutionStatus {
  SUCCESS
  FAILURE
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  name         String
  createdAt    DateTime        @default(now())
  memberships  OrgMembership[]
}

model Organization {
  id          String          @id @default(uuid())
  name        String
  createdAt   DateTime        @default(now())
  memberships OrgMembership[]
  projects    Project[]
}

model OrgMembership {
  id             String       @id @default(uuid())
  userId         String
  orgId          String
  role           Role         @default(MEMBER)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

model Project {
  id             String       @id @default(uuid())
  orgId          String
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  queues         Queue[]
}

model RetryPolicy {
  id          String        @id @default(uuid())
  name        String
  strategy    RetryStrategy
  baseDelayMs Int
  maxRetries  Int
  maxDelayMs  Int
  queues      Queue[]
}

model Queue {
  id               String       @id @default(uuid())
  projectId        String
  name             String
  priority         Int          @default(0)
  concurrencyLimit Int          @default(5)
  status           QueueStatus  @default(ACTIVE)
  retryPolicyId    String?
  createdAt        DateTime     @default(now())
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  retryPolicy      RetryPolicy? @relation(fields: [retryPolicyId], references: [id], onDelete: SetNull)
  jobs             Job[]

  @@unique([projectId, name])
}

model Job {
  id                String         @id @default(uuid())
  queueId           String
  type              String
  payload           Json
  status            JobStatus      @default(QUEUED)
  priority          Int            @default(0)
  runAt             DateTime       @default(now())
  cronExpression    String?
  batchId           String?
  attempts          Int            @default(0)
  maxAttempts       Int            @default(3)
  claimedByWorkerId String?
  claimedAt         DateTime?
  idempotencyKey    String?        @unique
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  queue             Queue          @relation(fields: [queueId], references: [id], onDelete: Cascade)
  executions        JobExecution[]
  logs              JobLog[]
  deadLetterEntries DeadLetterEntry[]

  @@index([queueId, status, runAt])
}

model JobExecution {
  id           String          @id @default(uuid())
  jobId        String
  workerId     String
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?
  status       ExecutionStatus
  errorMessage String?
  durationMs   Int?
  job          Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobLog {
  id          String   @id @default(uuid())
  jobId       String
  executionId String?
  level       String   // INFO, WARN, ERROR
  message     String
  createdAt   DateTime @default(now())
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Worker {
  id              String            @id
  hostname        String
  pid             Int
  status          WorkerStatus      @default(ONLINE)
  lastHeartbeatAt DateTime          @default(now())
  startedAt       DateTime          @default(now())
  heartbeats      WorkerHeartbeat[]
}

enum WorkerStatus {
  ONLINE
  OFFLINE
  DRAINING
}

model WorkerHeartbeat {
  id          String   @id @default(uuid())
  workerId    String
  timestamp   DateTime @default(now())
  currentLoad Int
  metadata    Json?
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model DeadLetterEntry {
  id              String   @id @default(uuid())
  jobId           String
  reason          String
  failedAt        DateTime @default(now())
  originalPayload Json
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
